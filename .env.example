# Copy to .env, fill in the keys you need (see README.md for which sample
# needs what), then:
#   uv run --env-file .env samples/<script>.py
# Never commit the real .env — it's already in .gitignore.

# Create a bot via @BotFather on Telegram: https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_BOT_TOKEN=

# Create an app at https://api.slack.com/apps — App-Level Token (needs the
# connections:write scope) and Bot Token (under OAuth & Permissions).
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# No key — address of a locally running Ollama daemon, defaults to
# http://localhost:11434 if unset. Install: https://ollama.com
OLLAMA_HOST=

# No free tier, but inexpensive per request: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# No key — index or name of an audio input device (e.g. one containing
# "pulse" on WSL), from your system's list of available input devices.
WAKEN_MIC_DEVICE=
