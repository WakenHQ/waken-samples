# Copy to .env, fill in what the sample(s) you're running need, then:
#   uv run --env-file .env samples/<script>.py
# Never commit the real .env — it's already in .gitignore.

# telegram_bot.py
TELEGRAM_BOT_TOKEN=

# slack_bot.py
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# telegram_bot.py, file_drop_summarizer.py, github_issue_triage.py,
# scheduled_digest.py, multi_model_broadcast.py
GROQ_API_KEY=

# slack_bot.py, multi_model_broadcast.py
GEMINI_API_KEY=

# multi_model_broadcast.py (optional — falls back to an error entry if unset
# and no local daemon is running)
OLLAMA_HOST=
